// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS (Перерахування)
// ==========================================

enum Role {
  ADMIN
  MANAGER
  MECHANIC
}

enum OrderStatus {
  NEW // Нове (заявка)
  IN_PROGRESS // В роботі (механік робить)
  WAITING_PARTS // Очікує запчастин
  COMPLETED // Виконано (чекає оплати/видачі)
  PAID // Оплачено і закрито
  CANCELLED // Скасовано
}

enum OrderPriority {
  LOW
  MEDIUM
  HIGH
}

enum VehicleStatus {
  OUT // У клієнта (не на території СТО) - це дефолтний статус
  PENDING // Приїхала, стоїть на парковці/прийманні (очікує майстра)
  IN_SERVICE // Знаходиться в боксі (на підйомнику, в роботі)
  TEST_DRIVE // На тест-драйві (перевірка майстром)
  READY // Готова, стоїть на парковці видачі (чекає клієнта)
}

enum MovementType {
  RECEIVED // Прихід (зелений на графіку)
  ISSUED // Видано на ремонт/продаж (синій)
  RESERVED // Зарезервовано під замовлення (помаранчевий)
  RETURNED // Повернено з резерву або клієнтом (фіолетовий)
  ADJUSTMENT // Ручне коригування (через форму Edit Part)
}

enum ClientType {
  RETAIL
  WHOLESALE
  VIP
}

enum PartCondition {
  NEW
  USED
  REFURBISHED
}

// ==========================================
// PEOPLE & VEHICLES (Люди та Автомобілі)
// ==========================================

// 1. Таблиця ТІЛЬКИ для персоналу (Admin, Manager, Mechanic)
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String // Обов'язкове поле!
  role      Role      @default(MECHANIC)
  fullName  String
  avatar    String?
  deletedAt DateTime?

  // Зв'язки співробітника
  managerOrders  Order[]         @relation("ManagerOrders")
  mechanicOrders Order[]         @relation("MechanicOrders")
  serviceJobs    OrderService[]  @relation("ServiceMechanic") // Зв'язок з конкретними виконаними роботами
  stockMovements StockMovement[]
  chatSessions   ChatSession[]
  notifications  Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// 2. Таблиця ТІЛЬКИ для клієнтів (без паролів)
model Client {
  id       String  @id @default(cuid())
  fullName String
  phone    String  @unique // Для СТО телефон важливіший за email
  email    String?
  notes    String? // Нотатки про клієнта ("Любить каву", "Проблемний")

  // Денормалізовані поля для швидкого сортування
  totalSpent   Decimal   @default(0) @map("total_spent")
  totalOrders  Int       @default(0) @map("total_orders")
  vehicleCount Int       @default(0) @map("vehicle_count")
  latestVisit  DateTime? @map("latest_visit")

  // Зв'язки клієнта
  vehicles Vehicle[]
  orders   Order[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([totalSpent])
  @@index([totalOrders])
  @@index([vehicleCount])
  @@index([latestVisit])
  @@map("clients")
}

// 3. Автомобілі
model Vehicle {
  id          String  @id @default(cuid())
  vin         String  @unique // VIN-код унікальний
  brand       String // Марка (BMW)
  model       String // Модель (X5)
  year        Int // Рік випуску
  plateNumber String? @map("plate_number") // Держ. номер
  mileage     Int // Поточний загальний пробіг

  ownerId String @map("owner_id")
  owner   Client @relation(fields: [ownerId], references: [id])

  lastService   DateTime?     @map("last_service_date")
  totalServices Int           @default(0) @map("total_services") // Кількість виконаних робіт
  notes         String? // Нотатки про авто
  color         String?
  status        VehicleStatus @default(OUT)

  orders Order[]

  deletedAt DateTime?
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("vehicles")
}

// ==========================================
// CATALOGS & INVENTORY (Склад та Довідники)
// ==========================================

model PartCategory {
  id   String @id @default(cuid())
  name String // Назва категорії (наприклад, "Fluids")

  parts              Part[]
  requiredByServices Service[] @relation("ServiceToCategory")

  @@map("part_categories")
}

model ServiceCategory {
  id       String    @id @default(cuid())
  name     String // Назва категорії (наприклад, "Діагностика")
  services Service[]

  @@map("service_categories")
}

model PartsManufacturer {
  id    String @id @default(cuid())
  name  String @unique
  parts Part[]

  @@map("parts_manufacturers")
}

model PartsBrand {
  id    String @id @default(cuid())
  name  String @unique
  parts Part[]

  @@map("parts_brands")
}

model PartsSupplier {
  id      String  @id @default(cuid())
  name    String  @unique
  contact String?
  parts   Part[]

  @@map("parts_suppliers")
}

model Part {
  id   String  @id @default(cuid())
  code String? @unique
  name String
  sku  String  @unique
  oem  String?

  categoryId String
  category   PartCategory @relation(fields: [categoryId], references: [id])

  brandId String
  brand   PartsBrand @relation(fields: [brandId], references: [id])

  barcode       String?
  compatibility String[]
  crossNumbers  String[]

  unit     String?
  minStock Int?

  supplierId      String?
  supplier        PartsSupplier? @relation(fields: [supplierId], references: [id])
  supplierContact String?

  condition      PartCondition?
  warrantyMonths Int?
  warrantyKm     Int?

  weight     String?
  dimensions String?
  photo      String?
  notes      String?

  manufacturerId String?
  manufacturer   PartsManufacturer? @relation(fields: [manufacturerId], references: [id])

  inventory      PartInventory[]
  priceRules     PartPriceRule[]
  orderParts     OrderPart[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("parts")
}

model PartInventory {
  id            String   @id @default(cuid())
  partId        String
  part          Part     @relation(fields: [partId], references: [id])
  quantity      Int
  purchasePrice Decimal  @db.Decimal(10, 2)
  location      String?
  batchNumber   String? // номер партії
  receivedAt    DateTime @default(now())

  @@index([partId])
}

model StockMovement {
  id       String       @id @default(cuid())
  partId   String       @map("part_id")
  part     Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  type     MovementType
  quantity Int // Може бути +10 (прихід) або -2 (видача)
  reason   String? // Опис
  userId   String?      @map("user_id")
  user     User?        @relation(fields: [userId], references: [id])
  orderId  String?      @map("order_id")
  order    Order?       @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("stock_movements")
}

model PartPriceRule {
  id            String      @id @default(cuid())
  partId        String
  part          Part        @relation(fields: [partId], references: [id])
  clientType    ClientType?
  markupPercent Int?
  fixedPrice    Decimal?    @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  @@index([partId])
}

// ==========================================
// SERVICES & ORDERS (Послуги та Замовлення)
// ==========================================

model Service {
  id            String  @id @default(cuid())
  name          String // Назва роботи (Заміна мастила)
  description   String  @db.Text
  price         Decimal @default(0) @map("price") @db.Decimal(10, 2)
  estimatedTime Float   @default(1.0) @map("estimated_time")
  status        Boolean @default(true)

  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id])

  requiredCategories PartCategory[] @relation("ServiceToCategory")
  orderServices      OrderService[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("services")
}

model Order {
  id          String      @id @default(uuid())
  orderNumber Int         @unique @default(autoincrement()) @map("order_number")
  status      OrderStatus @default(NEW)
  description String?     @db.Text

  mileage         Int      @map("vehicle_mileage") // Пробіг на момент ремонту
  discount        Decimal? @default(0) @db.Decimal(10, 2) // Сума знижки
  recommendations String?  @db.Text // Рекомендації для клієнта (на майбутнє)

  totalAmount Decimal       @default(0) @map("total_amount") @db.Decimal(10, 2)
  priority    OrderPriority @default(MEDIUM)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  clientId String @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  managerId String? @map("manager_id")
  manager   User?   @relation("ManagerOrders", fields: [managerId], references: [id])

  mechanicId String? @map("mechanic_id")
  mechanic   User?   @relation("MechanicOrders", fields: [mechanicId], references: [id])

  parts          OrderPart[]
  services       OrderService[]
  stockMovements StockMovement[]

  deletedAt DateTime?
  startDate DateTime  @default(now()) @map("start_date")
  endDate   DateTime? @map("end_date")

  @@map("orders")
}

model OrderPart {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  partId String @map("part_id")
  part   Part   @relation(fields: [partId], references: [id])

  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2) // Фіксація ціни на момент продажу

  @@map("order_parts")
}

model OrderService {
  id      String @id @default(cuid())
  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  mechanicId String? @map("mechanic_id")
  mechanic   User?   @relation("ServiceMechanic", fields: [mechanicId], references: [id]) // Конкретний виконавець роботи

  quantity Float   @default(1)
  price    Decimal @db.Decimal(10, 2) // Фіксація ціни на момент продажу

  @@map("order_services")
}

// ==========================================
// KNOWLEDGE BASE (База знань AI)
// ==========================================

model Document {
  id         String   @id @default(cuid())
  filename   String // Назва файлу (Manual_Golf_5.pdf)
  content    String   @db.Text // Текст, витягнутий з PDF
  externalId String?  @map("external_id") // ID вектора в Pinecone
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("documents")
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum NotificationType {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_COMPLETED
  PART_DELIVERED
  SYSTEM
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String
  userId    String?       @map("user_id")
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String          @id @default(cuid())
  chatId    String          @map("chat_id")
  chat      ChatSession     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      ChatMessageRole
  content   String          @db.Text
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([chatId, createdAt])
  @@map("chat_messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(SYSTEM)
  title     String?
  message   String
  metadata  Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}
